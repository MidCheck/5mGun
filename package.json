{
  "name": "5mgun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "5mGun — 网页多人 FPS，5 分钟爽枪",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w shared run build && npm -w client run build",
    "start": "npm -w server run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
